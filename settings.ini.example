[DEFAULT]
# Keine Inline-Kommentare hinter Werten verwenden.

# Comdirect-Zugang
user=Zugangsnummer

# Passwort bitte nicht in settings.ini speichern.
# pwd wird bei Bedarf aus Secret-Backend gelesen oder beim ersten Start abgefragt und gespeichert.

# Comdirect API Access
clientId=****

# Client Secret bitte nicht in settings.ini speichern.
# clientSecret wird bei Bedarf aus Secret-Backend gelesen oder beim ersten Start abgefragt und gespeichert.

# Zielverzeichnis
outputDir=U:\\MyMoney\\Banking\\comdirect\\

# Testlauf: Bei True wird nichts heruntergeladen.
dryRun=False

# Wenn mehrere Dateien den gleichen Namen haben, wird zuerst versucht,
# das Datum an den Dateinamen anzuhängen.
appendIfNameExists=True

# Bestehende Option: Sortierung nach MIME-Typ, z. B. pdf/html.
useSubFolders=False

# Neue Option: Sortierung nach comdirect-Dokumenttyp.
# Ordnernamen entsprechen exakt den Dokumenttypen, keine Pluralisierung.
useThematicSubFolders=True

# Neue Option: Bereits vorhandene lokale Dateien erkennen und überspringen.
incrementalSync=True

# Nur Dokumente herunterladen, deren Dokumenttyp in der Liste enthalten ist.
downloadOnlyFilenames=True

downloadOnlyFilenamesArray={"Finanzreport", "Jahressteuerbescheinigung", "Wertpapierabrechnung", "Steuermitteilung", "Gutschrift", "Dividendengutschrift", "Ertragsgutschrift", "Kosteninformation"}

# archivedOnly / notArchivedOnly / all
downloadSource=all

# Secret-Backend:
# auto = Windows: keyring / Linux oder Raspberry Pi: .env
# keyring = immer Python keyring verwenden
# env = immer lokale .env verwenden
secretBackend=auto

# Namensraum für Windows Credential Manager / Secret-Service
# Nicht MarketDataLab verwenden.
secretNamespace=Banking/comdirect
